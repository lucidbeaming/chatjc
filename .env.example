# Required
MISTRAL_API_KEY=your-mistral-api-key

# Server
PORT=3000
HOST=0.0.0.0

# Database
DB_PATH=./data/chatjc.db

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=https://joshuacurry.dev

# Rate Limiting
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# Guardrails
MAX_INPUT_LENGTH=500
MAX_RESPONSE_LENGTH=1000

# Mistral Models
MISTRAL_CHAT_MODEL=mistral-small-latest
MISTRAL_EMBED_MODEL=mistral-embed

# RAG
CONTEXT_DIR=./context/mock    # Use ./context/live for real data
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=4
